generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Recipe {
  id           Int          @id @default(autoincrement())
  name         String
  tags         String[]
  ingredients  Ingredient[]
  instructions String[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  // Ajout des relations inverses
  midiPlans    WeeklyPlan[] @relation("MidiRecipe")
  soirPlans    WeeklyPlan[] @relation("SoirRecipe")
}

model Ingredient {
  id       Int      @id @default(autoincrement())
  name     String
  quantity Float
  unit     String
  category String
  recipeId Int
  recipe   Recipe   @relation(fields: [recipeId], references: [id])
}

model WeeklyPlan {
  id        Int      @id @default(autoincrement())
  day       String
  midiId    Int?
  soirId    Int?
  midi      Recipe?  @relation("MidiRecipe", fields: [midiId], references: [id])
  soir      Recipe?  @relation("SoirRecipe", fields: [soirId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([day])
}